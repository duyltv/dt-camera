# DT Camera environment reference.
#
# Copy this file to `.env`, then edit the values:
#   cp .env.example .env
#
# Docker Compose automatically reads `.env`. Most values below are consumed by
# docker-compose.yml and then passed into the right container. Variables marked
# "direct-run only" are useful when running binaries or scripts outside Compose.


# ---------------------------------------------------------------------------
# Compose and public access
# ---------------------------------------------------------------------------

# The only public port exposed by the default Compose stack. Nginx serves the
# React app, /api, and /hls from one origin so browser cookies work cleanly.
APP_PORT=8088

# Environment mode checked by the backend safety guard. Use blank/development
# for local work, staging for pre-prod, and production for real deployments.
# Production refuses insecure settings such as COOKIE_SECURE=false.
APP_ENV=

# Public browser origin of the app. With the default nginx setup this should
# match APP_PORT. In production set this to your HTTPS URL.
FRONTEND_ORIGIN=http://localhost:8088

# Direct debug ports. They are not exposed unless you uncomment the matching
# ports blocks in docker-compose.yml.
BACKEND_PORT=8080
FRONTEND_PORT=5173


# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

# Database name/user/password created by the postgres container.
# Change POSTGRES_PASSWORD before production.
POSTGRES_DB=dt_camera
POSTGRES_USER=dt_camera
POSTGRES_PASSWORD=change-me

# direct-run only: full backend/recorder/migrate database URL. Compose builds
# this internally from POSTGRES_* and the postgres service name.
# DATABASE_URL=postgres://dt_camera:change-me@localhost:5432/dt_camera?sslmode=disable

# scripts/backup.sh and scripts/restore.sh: PostgreSQL host/port reachable from
# the machine running the script. Defaults point at a local Postgres port.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432


# ---------------------------------------------------------------------------
# Bootstrap admin
# ---------------------------------------------------------------------------

# Optional first-admin bootstrap. Set both values only when intentionally
# creating the first admin user. The backend will not silently create default
# credentials. In production the password must be strong.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=


# ---------------------------------------------------------------------------
# Sessions, cookies, and login protection
# ---------------------------------------------------------------------------

# Session lifetime in hours. 2160 hours = 90 days from the last login.
SESSION_TTL_HOURS=2160

# How often expired or revoked sessions are cleaned up. Go duration format.
SESSION_CLEANUP_INTERVAL_SECONDS=15m

# Set true behind HTTPS in production so session cookies are sent only over TLS.
COOKIE_SECURE=false

# Optional cookie domain for cross-subdomain deployments, for example
# .example.com. Leave blank for the current host only.
COOKIE_DOMAIN=

# Login rate limiting. These are in-memory backend limits:
# - per key means per (IP address + login/email)
# - per IP limits all attempted logins from the same IP
# Window/block values use Go duration format.
LOGIN_RATE_LIMIT_PER_KEY=10
LOGIN_RATE_LIMIT_PER_IP=50
LOGIN_RATE_LIMIT_WINDOW=1m
LOGIN_RATE_LIMIT_BLOCK_FOR=5m


# ---------------------------------------------------------------------------
# Recording storage
# ---------------------------------------------------------------------------

# Host folder where recorded video files persist. This is bind-mounted into
# backend and recorder containers.
RECORDINGS_HOST_PATH=./data/recordings

# Container path for recordings. Camera storage locations should use paths
# under this root, commonly /recordings.
RECORDINGS_CONTAINER_PATH=/recordings

# direct-run only: backend/recorder container-side recording root. Compose maps
# this from RECORDINGS_CONTAINER_PATH.
# RECORDINGS_PATH=/recordings


# ---------------------------------------------------------------------------
# Backend HTTP and live HLS
# ---------------------------------------------------------------------------

# direct-run only: backend listen address. Compose uses :8080 internally.
# APP_ADDR=:8080

# Container-side folder where backend writes temporary HLS live playlists and
# short segments. In Compose this is a named Docker volume.
HLS_ROOT=/tmp/dt-camera-hls

# Stop an on-demand live HLS ffmpeg process after this many seconds without
# viewers. Warm mode below normally keeps enabled cameras available.
HLS_INACTIVITY_SECONDS=60

# Keep enabled camera live streams warm in the background so opening Live is
# fast and less tied to user clicks.
HLS_WARM_ENABLED=true

# How often backend checks enabled cameras and starts/stops warm HLS streams.
# Go duration format.
HLS_WARM_INTERVAL_SECONDS=15s

# Maximum acceptable live lag. If the newest HLS segment is older than this,
# backend treats the stream as stale, restarts ffmpeg, and serves a fresh
# playlist URL. Go duration format.
HLS_MAX_LAG_SECONDS=30s

# Container-side folder for cached camera preview snapshots. In Compose this is
# a named Docker volume so previews remain available when a stream is down.
PREVIEW_CACHE_ROOT=/var/lib/dt-camera/previews

# direct-run only: Vite frontend API base URL. Leave blank when using nginx
# single-origin routing; set to http://localhost:8080 only when debugging the
# frontend directly against an exposed backend port.
VITE_API_BASE_URL=


# ---------------------------------------------------------------------------
# Recorder worker
# ---------------------------------------------------------------------------

# Logical recorder name written to recorder_heartbeats and logs.
RECORDER_WORKER_ID=recorder-1

# How often recorder polls the database for enabled/disabled camera config.
# Integer seconds.
RECORDER_POLL_INTERVAL_SECONDS=5

# Length of normal recording segments created by ffmpeg. Integer seconds.
RECORDER_SEGMENT_SECONDS=60

# Maximum retry backoff after a failed RTSP recording attempt. Integer seconds.
RECORDER_MAX_BACKOFF_SECONDS=60

# How old a segment file must be before the recorder considers it stable enough
# to insert metadata for it. Integer seconds.
RECORDER_STABLE_FILE_AGE_SECONDS=8

# How often recorder runs retention and low-disk cleanup. Integer seconds.
RECORDER_CLEANUP_INTERVAL_SECONDS=60

# Free-space warning threshold used by low-disk cleanup. When storage free
# space drops below this percent, the recorder deletes oldest eligible segment
# files first.
RECORDER_LOW_DISK_FREE_PERCENT=10

# Low-disk cleanup will only delete referenced recording files at least this old.
# Integer seconds.
RECORDER_LOW_DISK_MIN_FILE_AGE_SECONDS=3600


# ---------------------------------------------------------------------------
# Operational retention and health history
# ---------------------------------------------------------------------------

# Backend operational cleanup cadence and retention windows. Values use Go
# duration format. Error-level system events are kept indefinitely.
EVENT_RETENTION_HOURS=720h
ALERT_RETENTION_HOURS=2160h
HEARTBEAT_RETENTION_HOURS=168h
REVOKED_SESSION_HOURS=24h
RETENTION_INTERVAL_SECONDS=6h

# How often alert rules, including motion-triggered notification rules, are
# evaluated. Go duration format.
ALERT_EVAL_INTERVAL_SECONDS=1m


# ---------------------------------------------------------------------------
# Backup and restore scripts
# ---------------------------------------------------------------------------

# scripts/backup.sh output folder. The script writes dt-camera-<timestamp>.tar.gz
# here unless --out is provided.
BACKUP_DIR=./backups

# scripts/backup.sh pg_dump format. Usually keep "custom" so restore can use
# pg_restore safely.
PG_DUMP_FORMAT=custom

# Reserved by scripts/backup.sh for Docker service naming. Current backup logic
# does not require changing this value.
DOCKER_PG_SERVICE=postgres

# Optional build identity values written into backup manifests.
GIT_COMMIT=
BUILD_TIME=


# ---------------------------------------------------------------------------
# Production notes
# ---------------------------------------------------------------------------

# For production, use at least:
#   APP_ENV=production
#   COOKIE_SECURE=true
#   FRONTEND_ORIGIN=https://your-camera-domain.example
#   POSTGRES_PASSWORD=<strong-password>
#   BOOTSTRAP_ADMIN_EMAIL=<first-admin-email>
#   BOOTSTRAP_ADMIN_PASSWORD=<strong-first-admin-password>
#
# Then start with:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
