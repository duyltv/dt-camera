POSTGRES_DB=dt_camera
POSTGRES_USER=dt_camera
POSTGRES_PASSWORD=change-me

# APP_PORT is the only port exposed by nginx. The whole app is reached
# through a single origin (default http://127.0.0.1:8088) so the SPA, the
# /api endpoints, and the /hls playlist all share the same host. Cookies
# set by /api/auth/login are visible to subsequent /api/* calls without
# any CORS dance.
APP_PORT=8088

# Direct backend/frontend ports are OFF by default. Uncomment the relevant
# ports: block in docker-compose.yml to debug a single service in isolation.
# BACKEND_PORT=8080
# FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:8088
SESSION_TTL_HOURS=2160
SESSION_CLEANUP_INTERVAL_SECONDS=15m

# Cookie hardening (set COOKIE_SECURE=true in production behind HTTPS).
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Login rate limiting (in-memory, per (ip, login) and per ip).
LOGIN_RATE_LIMIT_PER_KEY=10
LOGIN_RATE_LIMIT_PER_IP=50
LOGIN_RATE_LIMIT_WINDOW=1m
LOGIN_RATE_LIMIT_BLOCK_FOR=5m

# Alert evaluator cadence.
ALERT_EVAL_INTERVAL_SECONDS=1m

# Operational retention (defaults are conservative).
# EVENT_RETENTION_HOURS deletes system_events older than this many hours (errors kept forever).
# ALERT_RETENTION_HOURS deletes resolved/acknowledged alerts older than this many hours.
# HEARTBEAT_RETENTION_HOURS prunes recorder_heartbeats older than this many hours.
# REVOKED_SESSION_HOURS hard-deletes revoked sessions older than this many hours.
# RETENTION_INTERVAL_SECONDS is how often the cleanup pass runs.
EVENT_RETENTION_HOURS=720h
ALERT_RETENTION_HOURS=2160h
HEARTBEAT_RETENTION_HOURS=168h
REVOKED_SESSION_HOURS=24h
RETENTION_INTERVAL_SECONDS=6h

HLS_ROOT=/tmp/dt-camera-hls
HLS_INACTIVITY_SECONDS=60
HLS_WARM_ENABLED=true
HLS_WARM_INTERVAL_SECONDS=15s
PREVIEW_CACHE_ROOT=/var/lib/dt-camera/previews

# Optional first-admin bootstrap. Leave blank unless intentionally creating one.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

RECORDINGS_HOST_PATH=./data/recordings
RECORDINGS_CONTAINER_PATH=/recordings

RECORDER_WORKER_ID=recorder-1
RECORDER_POLL_INTERVAL_SECONDS=5
RECORDER_SEGMENT_SECONDS=60
RECORDER_MAX_BACKOFF_SECONDS=60
RECORDER_CLEANUP_INTERVAL_SECONDS=60
RECORDER_LOW_DISK_FREE_PERCENT=10
RECORDER_LOW_DISK_MIN_FILE_AGE_SECONDS=3600
